# Supabase — get from https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Pooled connection (transaction mode, port 6543) — use this from Vercel functions
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
# Direct connection (port 5432) — use this for migrations + ingestion script
SUPABASE_DB_DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Anthropic — Claude Sonnet with native Citations API
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI — embeddings (voyage-3) + reranker (rerank-2.5)
VOYAGE_API_KEY=pa-...

# Closed beta — comma-separated emails allowed to sign up
BETA_ALLOWLIST_EMAILS=grafiksein@gmail.com

# Admin role — comma-separated emails granted profiles.role='admin' on login
ADMIN_EMAILS=grafiksein@gmail.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Mistral — chat model (cheap-model experiment)
MISTRAL_API_KEY=...

# Google Gemini — chat model (cheap-model experiment)
GOOGLE_GENERATIVE_AI_API_KEY=...

# DeepSeek — chat model (cheap-model experiment)
DEEPSEEK_API_KEY=...